{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "King Console: Start",
      "type": "shell",
      "command": "node tools/king-console/server.js",
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": true
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "runOptions": {
        "runOn": "default"
      },
      "problemMatcher": []
    },
    {
      "label": "King Console: Open in Browser",
      "type": "shell",
      "command": "open http://localhost:4242 || xdg-open http://localhost:4242 || start http://localhost:4242",
      "group": "build",
      "presentation": {
        "reveal": "silent"
      },
      "problemMatcher": []
    }
  ]
}
